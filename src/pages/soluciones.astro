---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Soluciones from '../components/Soluciones.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import type { CasoExito, SolucionesData } from '../data/soluciones';

export const prerender = false;

const API_URL = import.meta.env.PUBLIC_API_URL || 'https://e3-admin-api.onrender.com';

const defaultData: SolucionesData = {
    titulo: 'Casos de Éxito',
    subtitulo: 'Descubre cómo hemos ayudado a organizaciones a transformar su incertidumbre en crecimiento structured.',
    casos: [
        {
            id: 1,
            slug: 'transformacion-empresarial',
            titulo: 'Transformación Empresarial',
            descripcion: 'Implementación de estrategia integral de resiliencia organizacional.',
            imagen: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&auto=format&fit=crop&q=60',
            testimonio: null
        },
        {
            id: 2,
            slug: 'analisis-de-mercado',
            titulo: 'Análisis de Mercado',
            descripcion: 'Estudio profundo del sector que permitió decisiones estratégicas fundamentadas.',
            imagen: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&auto=format&fit=crop&q=60',
            testimonio: null
        },
        {
            id: 3,
            slug: 'planificacion-estrategica',
            titulo: 'Planificación Estratégica',
            descripcion: 'Desarrollo de hoja de ruta para expansión con análisis de riesgo.',
            imagen: 'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=600&auto=format&fit=crop&q=60',
            testimonio: null
        }
    ]
};

let data: SolucionesData = defaultData;

try {
    const response = await fetch(`${API_URL}/api/contenido/soluciones`, { 
        signal: AbortSignal.timeout(5000) 
    });
    
    if (response.ok) {
        const apiData = await response.json();
        if (apiData && typeof apiData === 'object') {
            data = {
                titulo: apiData.titulo || defaultData.titulo,
                subtitulo: apiData.subtitulo || defaultData.subtitulo,
                casos: Array.isArray(apiData.casos) && apiData.casos.length > 0 
                    ? apiData.casos 
                    : defaultData.casos
            };
        }
    }
} catch (error) {
    console.error('API de soluciones no disponible, usando datos locales:', error);
}
---

<Layout title="Soluciones - E3" description="Casos de éxito y soluciones implementadas por E3">
    <Header />
    <Soluciones casos={data.casos} titulo={data.titulo} subtitulo={data.subtitulo} />
    <CTA />
    <Footer />
</Layout>
