---
import Carousel from './Carousel.astro';
import type { CarouselItem } from '../data/carouselItems';

interface Props {
    items: CarouselItem[];
    title: string;
    description: string;
}

const { items, title, description } = Astro.props;
---

<Carousel 
    items={items}
    title={title}
    description={description}
/>
