---
import { sectionBackgrounds } from '../data/backgroundImages';

const heroBackground = sectionBackgrounds.hero;
---

<section class="min-h-[90vh] flex items-center justify-center px-4 relative overflow-hidden">
	<div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-primary to-gray-900"></div>
	<div class="absolute inset-0 opacity-20" style={{ backgroundImage: 'radial-gradient(circle at 1px 1px, white 1px, transparent 0)', backgroundSize: '40px 40px' }}></div>
	
	<div class="absolute top-20 right-20 w-72 h-72 bg-primary/30 rounded-full blur-3xl"></div>
	<div class="absolute bottom-20 left-20 w-96 h-96 bg-secondary/20 rounded-full blur-3xl"></div>
	
	<div class="max-w-5xl mx-auto text-center relative z-10">
		<div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6 border border-white/20">
			<span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
			<span class="text-white/90 text-sm font-medium">Consultoría Estratégica de Alta Complejidad</span>
		</div>
		
		<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
			Transformamos la <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-secondary">Incertidumbre</span> en Crecimiento
		</h1>
		
		<p class="text-lg md:text-xl text-gray-300 mb-10 max-w-3xl mx-auto leading-relaxed">
			En E³ construimos la infraestructura del éxito. Soluciones estratégicas que integran análisis económico riguroso con precisión política para organizaciones verdaderamente resilientes.
		</p>
		
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a href="#contacto" class="group inline-flex items-center justify-center gap-2 bg-white text-gray-900 px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition-all hover:shadow-xl hover:-translate-y-1">
				Conoce a nuestros asesores
				<svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
				</svg>
			</a>
			<a href="#quienes-somos" class="inline-flex items-center justify-center gap-2 bg-transparent text-white border-2 border-white/30 px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition text-lg">
				Más información
			</a>
		</div>

		<div class="mt-16 grid grid-cols-3 gap-8 max-w-2xl mx-auto">
			<div class="text-center">
				<p class="text-3xl md:text-4xl font-bold text-white">+150</p>
				<p class="text-gray-400 text-sm">Proyectos Exitosos</p>
			</div>
			<div class="text-center">
				<p class="text-3xl md:text-4xl font-bold text-white">98%</p>
				<p class="text-gray-400 text-sm">Clientes Satisfechos</p>
			</div>
			<div class="text-center">
				<p class="text-3xl md:text-4xl font-bold text-white">+10</p>
				<p class="text-gray-400 text-sm">Años de Experiencia</p>
			</div>
		</div>
	</div>
</section>
