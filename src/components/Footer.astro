---
---

<footer class="bg-navy-950 text-white/80">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="py-16 border-t-4 border-gold-500">
			<div class="grid lg:grid-cols-4 gap-12">
				<div class="lg:col-span-1">
					<a href="/" class="flex items-center gap-3 mb-6 group">
						<img src="/e3.ico" alt="E3 Logo" class="w-12 h-12 transition-transform group-hover:scale-110" />
						<div class="flex flex-col">
							<span class="text-xl font-bold text-white">E³</span>
							<span class="text-xs text-gold-400 font-medium tracking-widest uppercase">Consultoría</span>
						</div>
					</a>
					<p class="text-white/60 text-sm leading-relaxed mb-6">
						Transformamos la incertidumbre en estructuras sólidas de crecimiento mediante soluciones estratégicas de alta complejidad.
					</p>
					<div class="flex items-center gap-2 text-gold-400 text-sm">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
						</svg>
						<span>Soluciones Certificadas</span>
					</div>
				</div>

				<div>
					<h4 class="text-white font-semibold mb-6 flex items-center gap-2">
						<span class="w-8 h-px bg-gold-400"></span>
						Empresa
					</h4>
					<ul class="space-y-4 text-sm">
						<li><a href="#quienes-somos" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Quiénes Somos
						</a></li>
						<li><a href="#mision-vision" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Misión y Visión
						</a></li>
						<li><a href="/soluciones" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Soluciones
						</a></li>
						<li><a href="#contacto" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Contacto
						</a></li>
					</ul>
				</div>

				<div>
					<h4 class="text-white font-semibold mb-6 flex items-center gap-2">
						<span class="w-8 h-px bg-gold-400"></span>
						Legal
					</h4>
					<ul class="space-y-4 text-sm">
						<li><a href="/privacidad" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Política de Privacidad
						</a></li>
						<li><a href="/terminos" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Términos de Servicio
						</a></li>
						<li><a href="/cookies" class="text-white/60 hover:text-gold-400 transition flex items-center gap-2 group">
							<span class="w-1.5 h-1.5 bg-gold-400/50 rounded-full group-hover:bg-gold-400 transition"></span>
							Cookies
						</a></li>
					</ul>
				</div>

				<div>
					<h4 class="text-white font-semibold mb-6 flex items-center gap-2">
						<span class="w-8 h-px bg-gold-400"></span>
						Síguenos
					</h4>
					<div class="flex gap-3">
						<a href="https://twitter.com" target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="w-11 h-11 bg-navy-800 border border-gold-500/30 rounded-xl flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 hover:border-gold-400 transition-all duration-300 hover:-translate-y-1">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
						</a>
						<a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="w-11 h-11 bg-navy-800 border border-gold-500/30 rounded-xl flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 hover:border-gold-400 transition-all duration-300 hover:-translate-y-1">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						</a>
						<a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-11 h-11 bg-navy-800 border border-gold-500/30 rounded-xl flex items-center justify-center hover:bg-gold-500 hover:text-navy-900 hover:border-gold-400 transition-all duration-300 hover:-translate-y-1">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</a>
					</div>
					
					<div class="mt-8 p-4 bg-navy-800/50 rounded-xl border border-gold-500/20">
						<p class="text-sm text-white/60 mb-2">¿Necesitas ayuda?</p>
						<a href="mailto:contacto@e3.com" class="text-gold-400 hover:text-gold-300 font-medium text-sm flex items-center gap-2">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
							</svg>
							contacto@e3.com
						</a>
					</div>
				</div>
			</div>
		</div>

		<div class="border-t border-gold-500/30 py-8">
			<div class="flex flex-col md:flex-row justify-between items-center gap-4">
				<div class="flex items-center gap-2">
					<span class="text-gold-400">©</span>
					<p class="text-sm text-white/50">2026 E³ Consultoría. Todos los derechos reservados.</p>
				</div>
				<div class="flex items-center gap-6 text-sm">
					<a href="/privacidad" class="text-white/50 hover:text-gold-400 transition">Política de Privacidad</a>
					<span class="text-gold-500/30">|</span>
					<a href="/terminos" class="text-white/50 hover:text-gold-400 transition">Términos</a>
				</div>
			</div>
		</div>
	</div>
</footer>
