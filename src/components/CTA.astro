---
import { getComponente } from '../data/componentes';
import { sectionBackgrounds } from '../data/backgroundImages';

const ctaBackground = sectionBackgrounds.cta;
const componente = await getComponente('CTA');
const titulo = componente?.titulo || 'Listo Para Construir Algo Asombroso?';
const contenido = componente?.contenido || 'Comienza a construir tu próximo proyecto con E³ hoy.';
const link = componente?.link || 'https://wa.me/526677800166';
const botonTexto = componente?.extra_data || 'Comienza a Construir Ahora';
---

<section class="relative py-24 overflow-hidden">
	<div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-950"></div>
	
	<div class="absolute inset-0">
		<div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gold-400/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
		<div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-gold-500/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>
	</div>

	<div class="absolute inset-0">
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-gold-400/50 to-transparent"></div>
		<div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-gold-400/30 to-transparent"></div>
	</div>

	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
		<div class="inline-flex items-center gap-3 mb-6">
			<div class="w-12 h-px bg-gradient-to-r from-transparent to-gold-400"></div>
			<span class="text-gold-400 text-sm font-medium tracking-widest uppercase">Transformamos tu visión</span>
			<div class="w-12 h-px bg-gradient-to-l from-transparent to-gold-400"></div>
		</div>
		
		<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6 leading-tight">
			{titulo}
		</h2>
		
		<p class="text-lg sm:text-xl text-white/70 mb-10 max-w-2xl mx-auto leading-relaxed">
			{contenido}
		</p>
		
		<button onclick={`window.open('${link}', '_blank')`} class="group relative inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-gold-400 to-gold-500 text-navy-900 font-bold text-lg rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-gold hover:-translate-y-1">
			<span class="relative z-10">{botonTexto}</span>
			<svg class="relative z-10 w-6 h-6 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
			</svg>
			<div class="absolute inset-0 bg-gradient-to-r from-gold-300 to-gold-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
		</button>
	</div>
</section>
