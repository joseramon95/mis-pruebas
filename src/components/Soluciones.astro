---
import type { CasoExito } from '../data/soluciones';

const API_URL = import.meta.env.PUBLIC_API_URL || 'https://e3-admin-api.onrender.com';

const defaultData = {
    titulo: 'Casos de Éxito',
    subtitulo: 'Descubre cómo hemos ayudado a organizaciones a transformar su incertidumbre en crecimiento.',
};

interface Props {
    titulo?: string;
    subtitulo?: string;
}

const { titulo = defaultData.titulo, subtitulo = defaultData.subtitulo } = Astro.props;

let casos: CasoExito[] = [];

try {
    const response = await fetch(`${API_URL}/api/contenido/soluciones`, {
        signal: AbortSignal.timeout(30000)
    });
    if (response.ok) {
        const data = await response.json();
        if (data && data.casos && Array.isArray(data.casos)) {
            casos = data.casos;
        }
    }
} catch {}
---

<section id="soluciones" class="py-24 px-4 bg-gradient-to-b from-navy-50 to-white">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
            <div class="inline-flex items-center gap-2 mb-4">
                <div class="w-12 h-px bg-gold-400"></div>
                <span class="text-gold-600 text-sm font-medium tracking-widest uppercase">Portfolio</span>
                <div class="w-12 h-px bg-gold-400"></div>
            </div>
            <h2 class="text-4xl md:text-5xl font-bold text-navy-900 mb-4">{titulo}</h2>
            <p class="text-lg text-navy-600 max-w-2xl mx-auto">{subtitulo}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {casos.map((caso) => (
                <a href={`/soluciones/${caso.slug}`} class="group block">
                    <div class="relative bg-white rounded-2xl overflow-hidden shadow-lg border border-navy-100 transition-all duration-500 hover:shadow-xl hover:-translate-y-2 hover:border-gold-400/50 h-full flex flex-col">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-gold-400/10 to-yellow-600/5 rounded-full blur-2xl group-hover:blur-3xl transition-all"></div>
                        
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="aspect-video overflow-hidden bg-navy-100">
                                <img 
                                    src={caso.imagen} 
                                    alt={caso.titulo}
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                />
                            </div>
                            
                            <div class="p-6 flex flex-col flex-1">
                                <h3 class="text-xl font-bold text-navy-900 mb-3 group-hover:text-gold-600 transition-colors">{caso.titulo}</h3>
                                <p class="text-navy-600 mb-4 flex-1">{caso.descripcion}</p>
                                
                                {caso.testimonio && (
                                    <div class="border-t border-gold-200 pt-4 mb-4 bg-gold-50/50 rounded-lg p-3">
                                        <p class="text-sm text-navy-600 italic mb-1">"{caso.testimonio.texto}"</p>
                                        <p class="text-sm font-semibold text-gold-600">— {caso.testimonio.autor}</p>
                                    </div>
                                )}
                                
                                <div class="mt-auto inline-flex items-center justify-center gap-2 w-full bg-gradient-to-r from-navy-800 to-navy-900 text-white px-6 py-3 rounded-xl font-bold hover:from-gold-500 hover:to-gold-600 hover:text-navy-900 transition-all duration-300 border-2 border-gold-400/50 group-hover:border-gold-400">
                                    <span>Ver Caso</span>
                                    <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>
