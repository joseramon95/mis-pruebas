---
import type { CasoExito } from '../data/soluciones';

interface Props {
    casos: CasoExito[];
    titulo: string;
    subtitulo: string;
}

const { casos, titulo, subtitulo } = Astro.props;
---

<section id="soluciones" class="py-20 px-4 bg-slate-50">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-bold text-navy-800 mb-4">{titulo}</h2>
            <p class="text-lg text-navy-600 max-w-2xl mx-auto">{subtitulo}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {casos.map((caso) => (
                <div class="caso-card relative bg-white rounded-xl p-1">
                    <div class="caso-inner relative bg-white rounded-lg p-6 h-full overflow-hidden flex flex-col">
                        <div class="absolute inset-0 rounded-lg pointer-events-none"></div>
                        
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="aspect-video rounded-lg overflow-hidden mb-4 bg-gray-100">
                                <img 
                                    src={caso.imagen} 
                                    alt={caso.titulo}
                                    class="w-full h-full object-cover"
                                />
                            </div>
                            
                            <h3 class="text-xl font-bold text-navy-800 mb-3">{caso.titulo}</h3>
                            <p class="text-slate-600 mb-4 flex-1">{caso.descripcion}</p>
                            
                            {caso.testimonio && (
                                <div class="testimonio border-l-4 border-gold-500 pl-4 mb-4">
                                    <p class="text-sm text-slate-500 italic mb-1">"{caso.testimonio.texto}"</p>
                                    <p class="text-sm font-semibold text-navy-800">{caso.testimonio.autor}</p>
                                </div>
                            )}
                            
                            <a 
                                href={`/soluciones/${caso.slug}`}
                                class="w-full mt-auto bg-navy-800 text-white px-6 py-3 rounded-lg font-bold text-center hover:bg-navy-900 transition-all shadow-lg border-2 border-gold-500 hover:scale-[1.02] flex items-center justify-center gap-2"
                            >
                                <span>Ver Caso</span>
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .caso-card {
        background: linear-gradient(135deg, #fde68a 0%, #fcd34d 50%, #fbbf24 100%);
        padding: 2px;
    }

    .caso-inner {
        box-shadow: 
            inset 0 0 20px rgba(251, 191, 36, 0.4),
            inset 3px 0 15px rgba(251, 191, 36, 0.5),
            inset -3px 0 15px rgba(251, 191, 36, 0.5),
            0 0 50px rgba(251, 191, 36, 0.3),
            0 0 100px rgba(251, 191, 36, 0.15),
            0 10px 30px rgba(0, 0, 0, 0.08);
        transition: all 0.4s ease;
    }

    .caso-card:hover .caso-inner {
        box-shadow: 
            inset 0 0 30px rgba(251, 191, 36, 0.5),
            inset 4px 0 20px rgba(251, 191, 36, 0.6),
            inset -4px 0 20px rgba(251, 191, 36, 0.6),
            0 0 80px rgba(251, 191, 36, 0.4),
            0 0 150px rgba(251, 191, 36, 0.2),
            0 15px 40px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }

    .testimonio {
        background: linear-gradient(90deg, rgba(251, 191, 36, 0.05) 0%, transparent 100%);
    }
</style>
