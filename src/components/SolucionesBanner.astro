---
interface Props {
    titulo?: string;
    subtitulo?: string;
    imagen?: string;
}

const { 
    titulo = 'Casos de Éxito', 
    subtitulo = 'Descubre cómo hemos ayudado a organizaciones a transformar su incertidumbre en crecimiento.', 
    imagen = 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=1200&auto=format&fit=crop&q=60' 
} = Astro.props;
---

<section id="casos-exito" class="py-20 px-4 bg-gradient-to-r from-navy-900 to-navy-800 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
        <img src={imagen} alt="" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/90 to-navy-800/90"></div>
    
    <div class="max-w-6xl mx-auto relative z-10">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="text-white">
                <h2 class="text-4xl font-bold mb-6">{titulo}</h2>
                <p class="text-xl text-white/80 mb-8 leading-relaxed">{subtitulo}</p>
                <a 
                    href="/soluciones"
                    class="inline-flex items-center gap-3 bg-gold-500 text-navy-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-gold-400 transition shadow-lg border-2 border-gold-400"
                >
                    <span>Ver Casos de Éxito</span>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </a>
            </div>
            
            <div class="relative">
                <div class="grid grid-cols-2 gap-4">
                    <div class="caso-preview bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 transition">
                        <div class="aspect-video rounded-lg overflow-hidden mb-3 bg-navy-700">
                            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=400&auto=format&fit=crop&q=60" alt="" class="w-full h-full object-cover opacity-80" />
                        </div>
                        <p class="text-white text-sm font-medium">Transformación Empresarial</p>
                    </div>
                    <div class="caso-preview bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 transition mt-8">
                        <div class="aspect-video rounded-lg overflow-hidden mb-3 bg-navy-700">
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&auto=format&fit=crop&q=60" alt="" class="w-full h-full object-cover opacity-80" />
                        </div>
                        <p class="text-white text-sm font-medium">Análisis de Mercado</p>
                    </div>
                    <div class="caso-preview bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 transition -mt-4">
                        <div class="aspect-video rounded-lg overflow-hidden mb-3 bg-navy-700">
                            <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=400&auto=format&fit=crop&q=60" alt="" class="w-full h-full object-cover opacity-80" />
                        </div>
                        <p class="text-white text-sm font-medium">Planificación Estratégica</p>
                    </div>
                    <div class="caso-preview bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:bg-white/20 transition mt-4">
                        <div class="aspect-video rounded-lg overflow-hidden mb-3 bg-navy-700">
                            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&auto=format&fit=crop&q=60" alt="" class="w-full h-full object-cover opacity-80" />
                        </div>
                        <p class="text-white text-sm font-medium">+ Casos</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .caso-preview:hover {
        transform: scale(1.02);
    }
</style>
