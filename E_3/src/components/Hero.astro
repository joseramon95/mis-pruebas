---
import { getComponente } from '../data/componentes';
import { sectionBackgrounds } from '../data/backgroundImages';

const heroBackground = sectionBackgrounds.hero;
const componente = await getComponente('Hero');
const titulo = componente?.titulo || 'Nosotros Resolvemos';
const subtitulo = componente?.subtitulo || 'Tus Problemas';
const contenido = componente?.contenido || 'Soluciones estratégicas de alta complejidad para transformar tu incertidumbre en crecimiento.';
const link = componente?.link || '/cotizaciones';
---

<section 
	class="min-h-screen flex items-center justify-center px-4 relative overflow-hidden"
	style={{
		backgroundImage: `url('${heroBackground.imageUrl}')`,
		backgroundSize: 'cover',
		backgroundPosition: 'center',
		backgroundAttachment: 'fixed',
	}}
>
	<div
		class="absolute inset-0"
		style={{
			background: heroBackground.gradientOverlay,
		}}
	></div>

	<div class="absolute top-10 right-10 w-40 h-40 bg-amber-300 rounded-full opacity-10 blur-3xl"></div>
	<div class="absolute bottom-10 left-10 w-40 h-40 bg-amber-400 rounded-full opacity-10 blur-3xl"></div>
	
	<div class="max-w-4xl mx-auto text-center relative z-10">
		<h1 class="text-3xl md:text-4xl font-semibold text-white mb-4">
			{titulo}
		</h1>
		<h2 class="text-6xl md:text-8xl font-bold text-gold-400 mb-8">
			{subtitulo}
		</h2>
		<p class="text-xl md:text-2xl text-white/90 mb-8 max-w-2xl mx-auto">
			{contenido}
		</p>
		<div class="flex justify-center">
			<a href={link} target="_blank" class="bg-gold-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-gold-300 transition text-lg shadow-lg border-2 border-gold-500">
				{componente?.extra_data || '¿Te Interesa Alguno de Nuestros Servicios?'}
			</a>
		</div>
	</div>
</section>
