---
---

<section id="contacto" class="py-20 px-4 bg-slate-50">
	<div class="max-w-4xl mx-auto">
		<div class="text-center mb-12">
			<h2 class="text-4xl font-bold text-indigo-900 mb-4">Contacto</h2>
			<p class="text-lg text-indigo-700">
				¿Tienes preguntas? Nos encantaría escucharte. Envíanos un mensaje.
			</p>
		</div>

		<!-- Formulario con Formspree -->
		<form action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST" class="bg-white rounded-lg border-2 border-amber-400 p-8 shadow-lg">
			<!-- Nombre y Email -->
			<div class="grid md:grid-cols-2 gap-6 mb-6">
				<div>
					<label for="name" class="block text-indigo-900 font-semibold mb-2">Nombre Completo</label>
					<input type="text" id="name" name="name" required class="w-full px-4 py-2 border-2 border-amber-400 rounded-lg focus:outline-none focus:border-indigo-800 focus:bg-amber-50 transition" placeholder="Tu nombre" />
				</div>
				<div>
					<label for="email" class="block text-indigo-900 font-semibold mb-2">Correo Electrónico</label>
					<input type="email" id="email" name="email" required class="w-full px-4 py-2 border-2 border-amber-400 rounded-lg focus:outline-none focus:border-indigo-800 focus:bg-amber-50 transition" placeholder="tu@email.com" />
				</div>
			</div>

			<!-- Teléfono -->
			<div class="mb-6">
				<label for="phone" class="block text-indigo-900 font-semibold mb-2">Teléfono (Opcional)</label>
				<input type="tel" id="phone" name="phone" class="w-full px-4 py-2 border-2 border-amber-400 rounded-lg focus:outline-none focus:border-indigo-800 focus:bg-amber-50 transition" placeholder="+52 000 000-0000" />
			</div>

			<!-- Asunto -->
			<div class="mb-6">
				<label for="subject" class="block text-indigo-900 font-semibold mb-2">Asunto</label>
				<input type="text" id="subject" name="subject" required class="w-full px-4 py-2 border-2 border-amber-400 rounded-lg focus:outline-none focus:border-indigo-800 focus:bg-amber-50 transition" placeholder="¿En qué podemos ayudarte?" />
			</div>

			<!-- Mensaje -->
			<div class="mb-8">
				<label for="message" class="block text-indigo-900 font-semibold mb-2">Mensaje</label>
				<textarea id="message" name="message" required rows="6" class="w-full px-4 py-2 border-2 border-amber-400 rounded-lg focus:outline-none focus:border-indigo-800 focus:bg-amber-50 transition resize-none" placeholder="Cuéntanos tu mensaje..."></textarea>
			</div>

			<!-- Botón Enviar -->
			<div class="flex justify-center">
				<button type="submit" class="bg-indigo-800 text-white px-10 py-3 rounded-lg font-bold hover:bg-indigo-900 transition transform hover:scale-105 shadow-lg">
					Enviar Mensaje
				</button>
			</div>

			<!-- Nota sobre Formspree -->
			<p class="text-sm text-slate-600 text-center mt-4">
				💡 Reemplaza "YOUR_FORMSPREE_ID" con tu ID de Formspree
			</p>
		</form>

		<!-- Información adicional -->
		<div class="grid md:grid-cols-3 gap-8 mt-12">
			<div class="text-center">
				<div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center border-2 border-indigo-800 rounded-full">
					<span class="text-xl text-indigo-800">✉</span>
				</div>
				<h3 class="font-bold text-indigo-900 mb-1">Email</h3>
				<p class="text-slate-600">PENDIENTE</p>
			</div>
			<div class="text-center">
				<div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center border-2 border-indigo-800 rounded-full">
					<span class="text-xl text-indigo-800">☎</span>
				</div>
				<h3 class="font-bold text-indigo-900 mb-1">Teléfono</h3>
				<p class="text-slate-600">+52 PENDIENTE</p>
			</div>
			<div class="text-center">
				<div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center border-2 border-indigo-800 rounded-full">
					<span class="text-xl text-indigo-800">◉</span>
				</div>
				<h3 class="font-bold text-indigo-900 mb-1">Ubicación</h3>
				<p class="text-slate-600">Culiacan, Sinaloa</p>
			</div>
		</div>
	</div>
</section>
