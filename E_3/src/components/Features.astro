---
import Carousel from './Carousel.astro';
import { getComponente } from '../data/componentes';
import type { CarouselItem } from '../data/carouselItems';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:5000';
const componente = await getComponente('Features');

let items: CarouselItem[] = [];

try {
    const response = await fetch(`${API_URL}/api/socios`);
    if (response.ok) {
        items = await response.json();
    }
} catch (error) {
    console.error('Error fetching socios:', error);
}

if (items.length === 0) {
    items = [
        {
            id: 1,
            title: 'Cargando...',
            description: 'Obteniendo datos del servidor',
            image: '/persona-no-bg.png',
            contact: { text: 'Contactar', link: '#' }
        }
    ];
}

const title = componente?.titulo || 'La Arquitectura de la Certeza en Entornos de Alta Complejidad';
const description = componente?.contenido || 'En un mercado definido por la volatilidad, E³ construye la infraestructura del éxito. No solo ofrecemos asesoría: transformamos la incertidumbre en activos de crecimiento mediante tres pilares innegociables.';
---

<Carousel 
    items={items}
    title={title}
    description={description}
/>
