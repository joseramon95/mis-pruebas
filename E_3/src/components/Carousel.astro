---
import type { CarouselItem } from '../data/carouselItems';
import { sectionBackgrounds } from '../data/backgroundImages';

interface Props {
	items: CarouselItem[];
	title?: string;
	description?: string;
}

const { items, title = 'POR QUE ESCOGERNOS?', description = 'Experimente la potencia de la arquitectura insular y la hidratación parcial para lograr tiempos de carga ultrarrápidos.' } = Astro.props;
const carouselBackground = sectionBackgrounds.carousel;
---

<section 
	id="carousel" 
	class="py-20 px-4 relative overflow-hidden"
	style={{
		backgroundImage: `url('${carouselBackground.imageUrl}')`,
		backgroundSize: 'cover',
		backgroundPosition: 'center',
		backgroundAttachment: 'fixed',
	}}
>
	<!-- Gradiente superpuesto -->
	<div
		class="absolute inset-0"
		style={{
			background: carouselBackground.gradientOverlay,
		}}
	></div>

	<div class="max-w-6xl mx-auto relative z-10">
		<h2 class="text-4xl font-bold text-center mb-4 text-indigo-900">
			{title}
		</h2>
		<p class="text-center text-indigo-700 mb-12 max-w-2xl mx-auto font-medium">
			{description}
		</p>

		<!-- Carousel Container -->
<div class="relative">
	<!-- Carousel Wrapper -->
	<div class="overflow-hidden rounded-lg">
		<div id="carousel-track" class="flex transition-transform duration-500 ease-out" style="width: 100%;">
			
			{items.map((item) => (
				<div class="min-w-full px-4 py-8 flex justify-center">
					
					<!-- CONTENEDOR CUADRADO -->
					<div class="w-full max-w-md aspect-square">
						
						<div class="bg-white rounded-lg p-6 border-l-4 border-amber-400 h-full flex flex-col justify-between hover:shadow-xl transition">
							
							<!-- Imagen -->
							<div class="w-32 h-32 object-contain mx-auto mb-4">
								<img 
									src={item.image} 
									alt={item.title} 
									class="w-full h-full object-cover"
								/>
							</div>

							<!-- Texto -->
							<div>
								<h3 class="text-xl font-bold mb-2 text-indigo-900">
									{item.title}
								</h3>

								<p class="text-slate-600 text-sm mb-4">
									{item.description}
								</p>
							</div>

							<!-- Botón -->
							<a href={item.contact.link} target="_blank" class="btn">
								{item.contact.text}
							</a>

						</div>

					</div>

				</div>
			))}

		</div>
	</div>
</div>
			<!-- Navigation Buttons -->
			<button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-16 bg-indigo-800 text-white p-3 rounded-full hover:bg-indigo-900 transition z-20">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
				</svg>
			</button>
			<button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-16 bg-indigo-800 text-white p-3 rounded-full hover:bg-indigo-900 transition z-20">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
				</svg>
			</button>

			<!-- Indicators -->
			<div id="carousel-indicators" class="flex justify-center gap-2 mt-8">
				{items.map((_, index) => (
					<button 
						class="indicator-btn w-3 h-3 rounded-full transition-all"
						data-index={index}
						aria-label={`Go to slide ${index + 1}`}
						style={index === 0 ? 'background-color: #1e1b4b; width: 24px;' : 'background-color: #c2410c;'}
					></button>
				))}
			</div>
		</div>

		<!-- Mensaje destacado final -->
		<div class="mt-16 text-center bg-white bg-opacity-80 rounded-lg p-8 border-2 border-amber-400 max-w-3xl mx-auto">
			<p class="text-2xl font-bold text-indigo-900 italic">
				"No solo señalamos el camino; diseñamos la estructura que lo hace transitable."
			</p>
		</div>
	</div>
</section>

<script>
	// Controlador: Lógica del carrusel (patrón MVC)
	class CarouselController {
		private track: HTMLElement;
		private indicators: HTMLElement[];
		private totalSlides: number;
		private currentIndex: number = 0;
		private isPaused: boolean = false;

		constructor(trackId: string, indicatorClass: string) {
			this.track = document.getElementById(trackId)!;
			this.indicators = Array.from(document.querySelectorAll(`.${indicatorClass}`));
			this.totalSlides = this.indicators.length;
			this.init();
		}

		private init() {
			// Event listeners para botones
			document.getElementById('prev-btn')?.addEventListener('click', () => this.prev());
			document.getElementById('next-btn')?.addEventListener('click', () => this.next());

			// Indicadores
			this.indicators.forEach((indicator, index) => {
				indicator.addEventListener('click', () => this.goToSlide(index));
			});

			// Auto-rotate cada 5 segundos
			setInterval(() => {
				if (!this.isPaused) {
					this.next();
				}
			}, 5000);

			// Pause on hover
			this.track.parentElement?.addEventListener('mouseenter', () => (this.isPaused = true));
			this.track.parentElement?.addEventListener('mouseleave', () => (this.isPaused = false));
		}

		private updateCarousel() {
			const offset = -100 * this.currentIndex;
			this.track.style.transform = `translateX(${offset}%)`;
			this.updateIndicators();
		}

		private updateIndicators() {
			this.indicators.forEach((indicator, index) => {
				if (index === this.currentIndex) {
					indicator.style.backgroundColor = '#1e1b4b';
					indicator.style.width = '24px';
				} else {
					indicator.style.backgroundColor = '#c2410c';
					indicator.style.width = '12px';
				}
			});
		}

		private next() {
			this.currentIndex = (this.currentIndex + 1) % this.totalSlides;
			this.updateCarousel();
		}

		private prev() {
			this.currentIndex = (this.currentIndex - 1 + this.totalSlides) % this.totalSlides;
			this.updateCarousel();
		}

		private goToSlide(index: number) {
			this.currentIndex = index;
			this.updateCarousel();
		}
	}

	// Inicializar carrusel
	new CarouselController('carousel-track', 'indicator-btn');
</script>

<style>
	#carousel-track {
		display: flex;
	}
</style>
